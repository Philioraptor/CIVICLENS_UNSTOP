# CivicLens Backend — Environment Variables
# Copy this file to .env and fill in your values

PORT=5000

# MongoDB Atlas Connection String
# Get from: https://cloud.mongodb.com → Connect → Drivers → copy the URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/civiclens?retryWrites=true&w=majority

# JWT Secret — use any long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# Your deployed frontend URL (update after deploying to Vercel)
CLIENT_URL=http://localhost:5173

# AI Summarization
# Option A: Hugging Face — get free key at https://huggingface.co/settings/tokens
# HUGGING_FACE_API_KEY=hf_your_key_here

# Option B: Google Gemini (recommended — you already have experience with it)
# GEMINI_API_KEY=your_gemini_api_key_here
HUGGING_FACE_API_KEY=mock-api-key
